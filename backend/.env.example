# Copy to .env and fill in values
APP_NAME=Phishing Detection API
DEBUG=false
PHISH_DB_PATH=data/phish_urls.db

# LLM (used only when verdict is Suspicious). Choose one: ollama | gemini
LLM_PROVIDER=ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama2
LLM_TIMEOUT_SEC=30
# For LLM_PROVIDER=gemini:
# GEMINI_API_KEY=your_key
# GEMINI_MODEL=gemini-1.5-flash
